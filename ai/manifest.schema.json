{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MarkZ AI infrastructure manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "project",
    "authorities",
    "instructionLayers",
    "workflows",
    "qualityGates",
    "evalSuites"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "project": { "type": "string", "minLength": 1 },
    "authorities": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "path", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 }
        }
      }
    },
    "instructionLayers": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["scope", "path"],
        "additionalProperties": false,
        "properties": {
          "scope": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 }
        }
      }
    },
    "workflows": {
      "type": "object",
      "required": ["visualChange", "contentPublish", "edgeDeploy"],
      "additionalProperties": {
        "type": "object",
        "required": ["risk", "prompt", "requiredCommands", "requiredEvidence"],
        "additionalProperties": false,
        "properties": {
          "risk": { "enum": ["low", "medium", "high", "critical"] },
          "prompt": { "type": "string", "minLength": 1 },
          "requiredCommands": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "requiredEvidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "qualityGates": {
      "type": "object",
      "required": ["fast", "complete", "production"],
      "additionalProperties": false,
      "properties": {
        "fast": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "complete": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "production": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "evalSuites": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "path", "runner"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "runner": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
