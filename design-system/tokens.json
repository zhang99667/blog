{
  "$schema": "./tokens.schema.json",
  "version": "1.3.0",
  "brand": {
    "name": "MarkZ",
    "wordmark": "MarkZ.",
    "tagline": "个人博客",
    "description": "技术、产品与日常的个人记录。",
    "domain": "markz.fun",
    "assetRevision": "v3",
    "wordmarkFont": "Noto Sans SC",
    "wordmarkWeight": 800,
    "dotScale": 0.23
  },
  "theme": {
    "fontOrigin": "googleFonts",
    "cdnCaching": true,
    "typography": {
      "header": {
        "name": "Noto Serif SC",
        "weights": [400, 700]
      },
      "body": {
        "name": "Noto Sans SC",
        "weights": [400, 600, 800],
        "includeItalic": true
      },
      "code": {
        "name": "JetBrains Mono",
        "weights": [400, 600, 700, 800]
      }
    },
    "colors": {
      "lightMode": {
        "light": "#fafaf8",
        "lightgray": "#e3e2dc",
        "gray": "#646962",
        "darkgray": "#454842",
        "dark": "#191c17",
        "secondary": "#1759b6",
        "tertiary": "#a64032",
        "highlight": "rgba(23, 89, 181, 0.11)",
        "textHighlight": "#f0d66a80"
      },
      "darkMode": {
        "light": "#171916",
        "lightgray": "#343733",
        "gray": "#858b84",
        "darkgray": "#d9ddd7",
        "dark": "#f1f4ed",
        "secondary": "#84b2f4",
        "tertiary": "#ef927b",
        "highlight": "rgba(132, 178, 244, 0.14)",
        "textHighlight": "#b69f2788"
      }
    }
  },
  "fixedColors": {
    "brandSurface": "#fafaf8",
    "brandInk": "#191c17",
    "brandMuted": "#454842",
    "brandAccent": "#1759b6",
    "brandLine": "#e3e2dc"
  },
  "shape": {
    "controlRadius": "4px",
    "imageRadius": "4px",
    "focusRadius": "2px"
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem"
  },
  "typeScale": {
    "display": { "fontSize": "5rem", "lineHeight": 1, "weight": 800 },
    "displayCompact": { "fontSize": "3.3rem", "lineHeight": 1, "weight": 800 },
    "headline": { "fontSize": "3rem", "lineHeight": 1.18, "weight": 700 },
    "headlineCompact": { "fontSize": "2.2rem", "lineHeight": 1.2, "weight": 700 },
    "title": { "fontSize": "2rem", "lineHeight": 1.4, "weight": 700 },
    "body": { "fontSize": "1rem", "lineHeight": 1.82, "weight": 400 },
    "label": { "fontSize": "0.78rem", "lineHeight": 1.4, "weight": 700 }
  },
  "layout": {
    "shellMax": "1080px",
    "articleMax": "760px",
    "homeMax": "1040px",
    "archiveMax": "920px",
    "readingMeasure": "75ch"
  },
  "breakpoints": {
    "compact": "800px",
    "wide": "1200px"
  },
  "interaction": {
    "targetMinimum": "24px",
    "targetComfortable": "44px",
    "focusWidth": "2px",
    "focusOffset": "3px"
  },
  "accessibility": {
    "textContrast": 4.5,
    "largeTextContrast": 3,
    "nonTextContrast": 3
  },
  "motion": {
    "fast": "160ms",
    "easing": "ease"
  }
}
